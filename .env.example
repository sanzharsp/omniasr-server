# Runtime configuration. Loaded automatically by the Python app.
MODEL_NAME=omniASR_CTC_300M_v2
ZERO_SHOT_MODEL_NAME=omniASR_LLM_7B_ZS
# Optional CTC model used solely for forced-alignment of word timestamps.
# Leave empty to fall back to the heuristic aligner.
ALIGNMENT_MODEL_NAME=omniASR_CTC_1B_v2

# Per-chunk language identification. "none" disables LID; "fasttext" enables
# text-based detection via lid.176.bin (baked into the image at build time).
OMNILINGUAL_LID_BACKEND=fasttext
OMNILINGUAL_LID_MODEL_PATH=/models/lid/lid.176.bin
# Nearest-anchor smoothing: short or low-confidence chunks inherit the
# language of the nearest "anchor" chunk on the timeline. A chunk is an
# anchor when it is long enough AND its LID confidence is high enough.
OMNILINGUAL_LID_SHORT_MAX_SECONDS=2.0
OMNILINGUAL_LID_SHORT_MAX_WORDS=3
OMNILINGUAL_LID_ANCHOR_MIN_CONFIDENCE=0.7
OMNILINGUAL_HOST=0.0.0.0
OMNILINGUAL_PORT=8081
OMNILINGUAL_ROOT_PATH=/omni-asr
OMNILINGUAL_DEVICE=cuda
OMNILINGUAL_BATCH_SIZE=4
OMNILINGUAL_PRELOAD_ZERO_SHOT=false
OMNILINGUAL_CHUNK_MAX_SECONDS=30
OMNILINGUAL_VAD_THRESHOLD=0.5
OMNILINGUAL_VAD_NEG_THRESHOLD=
OMNILINGUAL_VAD_MIN_SPEECH_MS=250
OMNILINGUAL_VAD_MIN_SILENCE_MS=300
OMNILINGUAL_VAD_SPEECH_PAD_MS=200

# Optional Docker build configuration. `build.sh` reads these values from `.env`
# when the same variables are not already set in the shell.
NAMESPACE=
LATEST_TAG=false
PUSH=false

# Optional fairseq cache directory override.
# FAIRSEQ2_CACHE_DIR=/models/fairseq2/assets
